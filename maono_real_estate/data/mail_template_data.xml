<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Bienvenue locataire ───────────────────────────────────────────── -->
    <record id="re_lease_welcome_email" model="mail.template">
        <field name="name">Immobilier — Bienvenue locataire (confirmation bail)</field>
        <field name="model_id" ref="maono_real_estate.model_re_lease"/>
        <field name="subject">Bienvenue — Votre contrat de bail {{ object.name }}</field>
        <field name="email_to">{{ object.tenant_id.email }}</field>
        <field name="body_html"><![CDATA[
<p>Bonjour {{ object.tenant_id.name }},</p>
<p>Nous avons le plaisir de vous confirmer la signature de votre bail pour le bien suivant :</p>
<table style="border-collapse:collapse;width:100%;margin:12px 0;">
    <tr><td style="padding:6px;font-weight:bold;">Référence bail :</td><td style="padding:6px;">{{ object.name }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Bien :</td><td style="padding:6px;">{{ object.property_id.name }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Durée :</td><td style="padding:6px;">Du {{ object.start_date }} au {{ object.end_date or 'Non défini' }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Loyer mensuel :</td><td style="padding:6px;">{{ object.lmr }} {{ object.currency_id.name }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Prochaine échéance :</td><td style="padding:6px;">{{ object.next_invoice_date }}</td></tr>
</table>
<p>Cordialement,<br/>L'équipe de gestion immobilière</p>
        ]]></field>
        <field name="auto_delete">True</field>
    </record>

    <!-- ── Quittance mensuelle ───────────────────────────────────────────── -->
    <record id="re_lease_quittance_email" model="mail.template">
        <field name="name">Immobilier — Nouvelle quittance de loyer</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="subject">Quittance de loyer — {{ object.name }} — {{ object.invoice_date }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html"><![CDATA[
<p>Bonjour {{ object.partner_id.name }},</p>
<p>Veuillez trouver ci-joint votre quittance de loyer.</p>
<table style="border-collapse:collapse;width:100%;margin:12px 0;">
    <tr><td style="padding:6px;font-weight:bold;">Référence :</td><td style="padding:6px;">{{ object.name }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Date :</td><td style="padding:6px;">{{ object.invoice_date }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Montant dû :</td><td style="padding:6px;">{{ object.amount_total }} {{ object.currency_id.name }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Date d'échéance :</td><td style="padding:6px;">{{ object.invoice_date_due }}</td></tr>
</table>
<p>Merci de procéder au règlement avant la date d'échéance.</p>
<p>Cordialement,<br/>L'équipe de gestion immobilière</p>
        ]]></field>
        <field name="auto_delete">True</field>
    </record>

    <!-- ── Rappel de paiement ────────────────────────────────────────────── -->
    <record id="re_lease_payment_reminder_email" model="mail.template">
        <field name="name">Immobilier — Rappel de paiement loyer</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="subject">⚠️ Rappel — Règlement en attente — {{ object.name }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html"><![CDATA[
<p>Bonjour {{ object.partner_id.name }},</p>
<p>Sauf erreur de notre part, votre loyer ci-dessous est toujours en attente de règlement :</p>
<table style="border-collapse:collapse;width:100%;margin:12px 0;background:#fff3bf;">
    <tr><td style="padding:8px;font-weight:bold;">Référence :</td><td style="padding:8px;">{{ object.name }}</td></tr>
    <tr><td style="padding:8px;font-weight:bold;">Montant dû :</td><td style="padding:8px;color:#c92a2a;font-weight:bold;">{{ object.amount_residual }} {{ object.currency_id.name }}</td></tr>
    <tr><td style="padding:8px;font-weight:bold;">Échéance :</td><td style="padding:8px;">{{ object.invoice_date_due }}</td></tr>
</table>
<p>Merci de régulariser cette situation dans les meilleurs délais afin d'éviter l'application de pénalités de retard.</p>
<p>Cordialement,<br/>L'équipe de gestion immobilière</p>
        ]]></field>
        <field name="auto_delete">True</field>
    </record>

    <!-- ── Alerte expiration bail ────────────────────────────────────────── -->
    <record id="re_lease_expiry_email" model="mail.template">
        <field name="name">Immobilier — Alerte expiration bail</field>
        <field name="model_id" ref="maono_real_estate.model_re_lease"/>
        <field name="subject">⏰ Votre bail {{ object.name }} arrive à échéance</field>
        <field name="email_to">{{ object.tenant_id.email }}</field>
        <field name="body_html"><![CDATA[
<p>Bonjour {{ object.tenant_id.name }},</p>
<p>Nous souhaitons vous informer que votre contrat de bail arrive prochainement à son terme :</p>
<table style="border-collapse:collapse;width:100%;margin:12px 0;">
    <tr><td style="padding:6px;font-weight:bold;">Bail :</td><td style="padding:6px;">{{ object.name }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Bien :</td><td style="padding:6px;">{{ object.property_id.name }}</td></tr>
    <tr><td style="padding:6px;font-weight:bold;">Date de fin :</td><td style="padding:6px;color:#c92a2a;font-weight:bold;">{{ object.end_date }}</td></tr>
</table>
<p>Si vous souhaitez renouveler votre bail, merci de vous rapprocher de notre équipe dans les plus brefs délais.</p>
<p>Cordialement,<br/>L'équipe de gestion immobilière</p>
        ]]></field>
        <field name="auto_delete">True</field>
    </record>

    <!-- ── Notification pénalité ─────────────────────────────────────────── -->
    <record id="re_penalty_notification_email" model="mail.template">
        <field name="name">Immobilier — Notification de pénalité</field>
        <field name="model_id" ref="maono_real_estate.model_re_penalty"/>
        <field name="subject">🔴 Pénalité de retard — {{ object.name }}</field>
        <field name="email_to">{{ object.lease_id.tenant_id.email }}</field>
        <field name="body_html"><![CDATA[
<p>Bonjour {{ object.lease_id.tenant_id.name }},</p>
<p>Une pénalité de retard a été générée sur votre bail :</p>
<table style="border-collapse:collapse;width:100%;margin:12px 0;background:#ffe3e3;">
    <tr><td style="padding:8px;font-weight:bold;">Bail :</td><td style="padding:8px;">{{ object.lease_id.name }}</td></tr>
    <tr><td style="padding:8px;font-weight:bold;">Référence pénalité :</td><td style="padding:8px;">{{ object.name }}</td></tr>
    <tr><td style="padding:8px;font-weight:bold;">Montant :</td><td style="padding:8px;color:#c92a2a;font-weight:bold;">{{ object.penalty_amount }} {{ object.currency_id.name }}</td></tr>
    <tr><td style="padding:8px;font-weight:bold;">Date :</td><td style="padding:8px;">{{ object.penalty_date }}</td></tr>
</table>
<p>Merci de régulariser votre situation le plus rapidement possible.</p>
<p>Cordialement,<br/>L'équipe de gestion immobilière</p>
        ]]></field>
        <field name="auto_delete">True</field>
    </record>

</odoo>