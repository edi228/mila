        <record id="close_reason_tenant_request" model="re.lease.close.reason">
            <field name="name">Demande du locataire</field>
        </record>
        <record id="close_reason_owner_request" model="re.lease.close.reason">
            <field name="name">Demande du propriétaire</field>
        </record>
        <record id="close_reason_non_payment" model="re.lease.close.reason">
            <field name="name">Défaut de paiement</field>
            <field name="is_protected" eval="True"/>
        </record>
        <record id="close_reason_end_of_term" model="re.lease.close.reason">
            <field name="name">Fin de terme contractuelle</field>
        </record>
        <record id="close_reason_mutual_agreement" model="re.lease.close.reason">
            <field name="name">Accord mutuel</field>
        </record>
        <record id="close_reason_force_majeure" model="re.lease.close.reason">
            <field name="name">Force majeure / Sinistre</field>
        </record>

    </data>
