<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Catégorie produit Immobilier -->
        <record id="product_category_rental" model="product.category">
            <field name="name">Immobilier / Services locatifs</field>
        </record>

        <!-- Produit Loyer de base -->
        <record id="product_re_rent" model="product.template">
            <field name="name">Loyer</field>
            <field name="type">service</field>
            <field name="categ_id" ref="product_category_rental"/>
            <field name="is_rental_service">True</field>
            <field name="invoice_policy">order</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
        </record>
    </data>
</odoo>
