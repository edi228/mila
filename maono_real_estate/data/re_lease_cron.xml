<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             CRON 1 : Génération quotidienne des quittances (06h00)
        ============================================================ -->
        <record id="ir_cron_re_lease_create_quittance" model="ir.cron">
            <field name="name">Immo : Génération des quittances</field>
            <field name="model_id" ref="model_re_lease"/>
            <field name="state">code</field>
            <field name="code">model._cron_lease_create_quittance()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- ============================================================
             CRON 2 : Alertes expiration bail (hebdomadaire)
        ============================================================ -->
        <record id="ir_cron_re_lease_expiration" model="ir.cron">
            <field name="name">Immo : Alertes baux expirant</field>
            <field name="model_id" ref="model_re_lease"/>
            <field name="state">code</field>
            <field name="code">model._cron_lease_expiration()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- ============================================================
             CRON 3 : Pénalités automatiques (quotidien 07h00)
        ============================================================ -->
        <record id="ir_cron_re_lease_auto_penalties" model="ir.cron">
            <field name="name">Immo : Calcul automatique pénalités</field>
            <field name="model_id" ref="model_re_lease"/>
            <field name="state">code</field>
            <field name="code">model._cron_lease_auto_penalties()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
