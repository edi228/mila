<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_re_lease_saving_rule_form" model="ir.ui.view">
        <field name="name">re.lease.saving.rule.form</field>
        <field name="model">re.lease.saving.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="mode"/>
                            <field name="value"/>
                            <field name="base"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="beneficiary"/>
                            <field name="beneficiary_partner_id" invisible="beneficiary != 'other'"/>
                            <field name="target_account_id"/>
                        </group>
                    </group>
                    <field name="note" string="Conditions"/>
                </sheet>
            </form>
        </field>
    </record>

</odoo>