<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_re_lease_plan_form" model="ir.ui.view">
        <field name="name">re.lease.plan.form</field>
        <field name="model">re.lease.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ex : Mensuel, Trimestriel…"/></h1>
                    </div>
                    <group>
                        <group string="Périodicité">
                            <field name="billing_period_value"/>
                            <field name="billing_period_unit"/>
                            <field name="billing_first_day"/>
                        </group>
                        <group string="Paramètres">
                            <field name="auto_close_limit"/>
                            <field name="notice_days"/>
                            <field name="indexation_rate" widget="percentage"/>
                        </group>
                    </group>
                    <group string="Portail locataire">
                        <field name="user_closable"/>
                        <field name="user_closable_options" invisible="not user_closable"/>
                        <field name="user_extend"/>
                        <field name="user_quantity"/>
                        <field name="pausable_by_user"/>
                    </group>
                    <group string="Communication">
                        <field name="invoice_mail_template_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_re_lease_plan_list" model="ir.ui.view">
        <field name="name">re.lease.plan.list</field>
        <field name="model">re.lease.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="billing_period_value"/>
                <field name="billing_period_unit"/>
                <field name="billing_first_day"/>
                <field name="notice_days"/>
                <field name="auto_close_limit"/>
            </list>
        </field>
    </record>

</odoo>