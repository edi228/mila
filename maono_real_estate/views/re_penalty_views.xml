<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_re_penalty_form" model="ir.ui.view">
        <field name="name">re.penalty.form</field>
        <field name="model">re.penalty</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirmer" type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_create_invoice" string="Facturer" type="object" class="oe_highlight"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Annuler" type="object"
                            invisible="state in ('invoiced', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Origine">
                            <field name="lease_id"/>
                            <field name="invoice_id"/>
                            <field name="schedule_id"/>
                            <field name="due_date"/>
                            <field name="days_late"/>
                        </group>
                        <group string="Calcul">
                            <field name="invoice_original_amount"/>
                            <field name="prior_penalties_amount"/>
                            <field name="cumulative_base"/>
                            <field name="mode"/>
                            <field name="rate_or_amount"/>
                            <field name="penalty_amount" class="fw-bold text-danger"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="detection_date"/>
                        <field name="penalty_invoice_id" readonly="1"/>
                        <field name="note" string="Justification"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vue liste améliorée -->
    <record id="view_re_penalty_list" model="ir.ui.view">
        <field name="name">re.penalty.list</field>
        <field name="model">re.penalty</field>
        <field name="arch" type="xml">
            <list
                decoration-danger="days_late &gt; 30"
                decoration-warning="days_late &gt; 15 and days_late &lt;= 30"
                decoration-muted="state == 'cancelled'">
                <field name="name" string="Réf."/>
                <field name="lease_id" string="Bail"/>
                <field name="invoice_id" string="Quittance"/>
                <field name="days_late" string="Retard (j.)"
                       decoration-danger="days_late &gt; 30"
                       decoration-warning="days_late &gt; 15 and days_late &lt;= 30"/>
                <field name="penalty_amount" string="Montant"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'invoiced'"
                       decoration-info="state == 'confirmed'"
                       decoration-muted="state == 'cancelled'"
                       string="Statut"/>
                <!-- Boutons inline sans ouvrir la fiche -->
                <button name="action_confirm" string="Confirmer" type="object"
                        icon="fa-check" title="Confirmer cette pénalité"
                        invisible="state != 'draft'"/>
                <button name="action_create_invoice" string="Facturer" type="object"
                        icon="fa-file-text-o" title="Créer la facture de pénalité"
                        invisible="state != 'confirmed'"/>
                <button name="action_cancel" string="Annuler" type="object"
                        icon="fa-times" title="Annuler cette pénalité"
                        invisible="state in ('invoiced', 'cancelled')"/>
            </list>
        </field>
    </record>

    <!-- Vue recherche -->
    <record id="view_re_penalty_search" model="ir.ui.view">
        <field name="name">re.penalty.search</field>
        <field name="model">re.penalty</field>
        <field name="arch" type="xml">
            <search string="Pénalités">
                <field name="name" string="Référence"/>
                <field name="lease_id" string="Bail"/>
                <field name="invoice_id" string="Quittance"/>
                <filter name="pending"   string="En attente" domain="[('state','=','draft')]"/>
                <filter name="confirmed" string="Confirmées" domain="[('state','=','confirmed')]"/>
                <filter name="invoiced"  string="Facturées"  domain="[('state','=','invoiced')]"/>
                <filter name="cancelled" string="Annulées"   domain="[('state','=','cancelled')]"/>
            </search>
        </field>
    </record>

    <record id="action_re_penalty" model="ir.actions.act_window">
        <field name="name">Pénalités</field>
        <field name="res_model">re.penalty</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Pénalités depuis un bail -->
    <record id="action_re_penalty_from_lease" model="ir.actions.act_window">
        <field name="name">Pénalités</field>
        <field name="res_model">re.penalty</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('lease_id', '=', active_id)]</field>
        <field name="context">{'default_lease_id': active_id}</field>
    </record>

</odoo>